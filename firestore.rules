// Firestore security rules for this project
// Active rules (collection-scoped): allow public reads, authenticated writes to app collections.
// Below are two additional example snippets (DEV_OPEN and ROLE_BASED) commented
// out for convenience. Edit and deploy with `firebase deploy --only firestore:rules`.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default: allow read for anything, deny writes by default
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Allow authenticated writes to app collections
    match /shifts/{shiftId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /assignments/{assignmentId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Users collection: allow reads to authenticated users; creation only by that user,
    // updates/deletes only by admin (example pattern below assumes `role` field exists)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Add other collections here and scope rules similarly.
  }
}

/*
====================
OPTIONAL: DEV_OPEN (UNSAFE — for local/dev only)
====================

// Use only in development or emulator. DO NOT deploy to production.

// rules_version = '2';
// service cloud.firestore {
//   match /databases/{database}/documents {
//     match /{document=**} {
//       allow read, write: if true;
//     }
//   }
// }

====================
OPTIONAL: ROLE_BASED (example admin-only writes)
====================

// This snippet shows how to restrict writes to admin users only. It expects a users
// document for the signed-in user with a `role` field set to 'admin'.

// rules_version = '2';
// service cloud.firestore {
//   match /databases/{database}/documents {
//     match /{document=**} {
//       allow read: if true;
//       allow write: if false;
//     }
//     match /{col}/{docId} {
//       allow read: if true;
//       allow write: if request.auth != null
//         && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
//     }
//   }
// }
*/
