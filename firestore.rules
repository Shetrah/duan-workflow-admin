rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasLowercaseAdminRole() {
      return hasUserProfile() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(["role"]) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role is string &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower() == "admin";
    }

    function hasUppercaseAdminRole() {
      return hasUserProfile() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(["Role"]) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.Role is string &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.Role.lower() == "admin";
    }

    function isActiveUser() {
      return hasUserProfile() &&
        (
          !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(["isActive"]) ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true
        );
    }

    function isAdmin() {
      return hasUserProfile() &&
        (hasLowercaseAdminRole() || hasUppercaseAdminRole()) &&
        isActiveUser();
    }

    /* =========================
       👤 USERS
    ========================== */
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    /* =========================
       🔔 NOTIFICATIONS
    ========================== */
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    /* =========================
       👷 STAFF
    ========================== */
    match /staff/{staffId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /* =========================
       📋 JOBS
    ========================== */
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /* =========================
       🗂 ASSIGNMENTS
    ========================== */
    match /assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /* =========================
       ⏰ SHIFTS
    ========================== */
    match /shifts/{shiftId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /* =========================
       📊 DASHBOARD STATS
    ========================== */
    match /stats/{statId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /* =========================
       🏢 DEPARTMENTS
    ========================== */
    match /departments/{departmentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /* =========================
       📦 RESOURCES
    ========================== */
    match /resources/{resourceId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
